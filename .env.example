# Application Configuration
PORT=3000
HOST_HTTP_PORT=8080
NODE_ENV=production # development, production
TIME_ZONE=America/Sao_Paulo
TRUST_PROXY=1

# ngrok
NGROK_DOMAIN=your-reserved-domain.ngrok-free.app
## Optional override. If omitted in Docker, APP_PUBLIC_BASE_URL defaults to https://${NGROK_DOMAIN}
# APP_PUBLIC_BASE_URL=https://your-reserved-domain.ngrok-free.app
# NGROK_AUTHTOKEN=your-ngrok-token
# TOKEN_NGROK=your-ngrok-token # legacy alias supported by the Docker entrypoint

# Security / Secrets Source
# Defines where the application looks for secrets (DB creds, JWT, etc.)
# Options: ENV (default), VAULT
SECRETS_SOURCE=ENV

# Database Configuration (MySQL)
# Required when SECRETS_SOURCE=ENV
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=password
DB_DATABASE=api_payments
DB_SSL_MODE=disable # disable, require, verify-ca, verify-full
TYPEORM_SYNCHRONIZE=false

# Database Pool Configuration
DB_POOL_MAX=20 # Maximum number of connections in pool (production default: 20, dev: 5)
DB_IDLE_TIMEOUT=10000 # Connection idle timeout in milliseconds

# Log Cleanup Configuration
WEBHOOK_LOG_RETENTION_DAYS=60 # Days to keep webhook logs
AUDIT_LOG_RETENTION_DAYS=90 # Days to keep audit logs
LOG_CLEANUP_BATCH_SIZE=500 # Number of logs to delete per batch

# Redis Configuration
REDIS_MODE=local # local, upstash
REDIS_HOST=redis # use "redis" for the bundled Docker service, or another host for an external Redis
REDIS_PORT=6379
REDIS_PASSWORD=redispass
REDIS_DB=0
REDIS_MAX_MEMORY=128mb
REDIS_MAX_MEMORY_POLICY=allkeys-lru
# UPSTASH_REDIS_URL=redis://... (Required if REDIS_MODE=upstash)

# Authentication & Security
# Required when SECRETS_SOURCE=ENV
JWT_SECRET=your-super-secret-jwt-key
SENSITIVE_FIELDS=password,token,secret,cpf,cnpj,creditCard

# Logging Configuration
LOG_LEVEL=info # debug, info, warn, error
LOG_DESTINATION=console # console, cloud, both
CLOUD_LOGGING_PROVIDER=oci # oci

# Audit Configuration
AUDIT_ALERT_ENABLED=true

# OCI Configuration (Optional for ENV mode, unless using Cloud Logging)
# OCI_REGION=us-ashburn-1
# OCI_CONFIG_FILE=~/.oci/config
# OCI_PROFILE=DEFAULT

# R2 Storage (Cloudflare)
# Required when SECRETS_SOURCE=ENV
# R2_SECRET_ACCESS_KEY=...
# R2_ACCESS_KEY_ID=...
# R2_ACCOUNT_ID=...

# Webhook Security
# Required when SECRETS_SOURCE=ENV
# WEBHOOK_ENCRYPTION_KEY=...
