{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      {
        "include": "swagger/portal/assets/**/*"
      },
      {
        "include": "swagger/portal/templates/**/*"
      }
    ],
    "watchAssets": true
  }
}
